---
interface Props {
  src: string;
}
const { src } = Astro.props;

import introVideoAsset from '../videos/SMPTE Lead In 2.mp4';
---

<div id="intro-overlay" class="intro-overlay">
  <video 
    id="intro-video" 
    src={introVideoAsset} 
    muted 
    playsinline
    autoplay
  ></video>
</div>

<style>
  .intro-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 9999;
    background: black;
    display: none; /* Hidden by default, shown via JS */
    transition: opacity 2s ease-out;
  }

  .intro-overlay.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
    const overlay = document.getElementById('intro-overlay');
    const video = document.getElementById('intro-video') as HTMLVideoElement;
    const mainContent = document.getElementById('main-content');
    const hasSeenIntro = sessionStorage.getItem('hasSeenIntro');
  
    if (hasSeenIntro) {
      // REPEAT VISIT: Hide video, show site instantly
      if (overlay) overlay.style.display = 'none';
      if (mainContent) {
        mainContent.style.opacity = '1';
        mainContent.style.visibility = 'visible';
      }
    } else {
      // FIRST VISIT: Run the cinematic sequence
      if (video && overlay && mainContent) {
        overlay.style.display = 'block';
  
        // 1. Hand-off logic (When video finishes)
        video.onended = () => {
          overlay.style.display = 'none';
          sessionStorage.setItem('hasSeenIntro', 'true');
  
          // Trigger vertical jump physics
          document.body.classList.add('lock-scroll');
          mainContent.classList.add('film-frame-up');
  
          // Cleanup after 1s animation
          setTimeout(() => {
            document.body.classList.remove('lock-scroll');
            mainContent.style.overflow = 'visible';
          }, 1000);
        };
  
        // 2. Optional: Subtle fade out just before video ends
        video.ontimeupdate = () => {
          if (video.duration - video.currentTime <= 0.2) {
            overlay.classList.add('fade-out');
          }
        };
      }
    }
  </script>