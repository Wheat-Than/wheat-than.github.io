---
// src/components/FilmDefects.astro
---
<div class="film-container">
  <div class="line" data-line></div>
  <div class="line" data-line></div>
  <div class="line" data-line></div>
  <div class="dust"></div>
  <div id="frame-flash"></div>
</div>

<style>
  /* Identical CSS as requested */
  .film-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 100;
      pointer-events: none;
      overflow: hidden;
      animation: film-shiver 0.15s infinite;
  }

  @keyframes film-shiver {
      0% { transform: translateX(0); }
      50% { transform: translateX(0.8px) translateY(0.2px); }
      100% { transform: translateX(0); }
  }

  .dust {
      position: absolute;
      inset: -50%;
      width: 200%;
      height: 200%;
      opacity: 0.35;
      background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
      background-size: 50vw 50vw;
      animation: dust-jump 0.5s steps(1) infinite;
  }

  @keyframes dust-jump {
      0%   { background-position: 0% 0%; }
      25%  { background-position: 20% 40%; }
      50%  { background-position: 60% 10%; }
      75%  { background-position: 40% 90%; }
  }

  .line {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 0.5px;
      background: rgba(255, 255, 255, 0.4); 
      box-shadow: 0 0 1px rgba(255, 255, 255, 0.2);
      display: none;
  }

  #frame-flash {
      position: absolute;
      inset: 0;
      background: white;
      opacity: 0;
      pointer-events: none;
  }

  .active-flash {
      animation: quick-flash 0.1s steps(1);
  }

  @keyframes quick-flash {
      0% { opacity: 0.15; }
      100% { opacity: 0; }
  }
</style>

<script>
  // Identical Script as requested
  function initFilmDefects() {
    const lines = document.querySelectorAll('[data-line]');
    
    lines.forEach((lineElement) => {
      const line = lineElement as HTMLElement;
      const randomizeLine = () => {
        line.style.left = `${Math.random() * 100}%`;
        line.style.display = 'block';
        const onScreenDuration = 25 + Math.random() * 175;
        
        setTimeout(() => {
          line.style.display = 'none';
          const waitDuration = 1000 + Math.random() * 9000;
          setTimeout(randomizeLine, waitDuration);
        }, onScreenDuration);
      };
      randomizeLine();
    });

    const flash = document.getElementById('frame-flash');
    function triggerFlash() {
      if (!flash) return;
      flash.classList.add('active-flash');
      flash.addEventListener('animationend', () => {
        flash.classList.remove('active-flash');
        const nextFlashDelay = 10000 + Math.random() * 90000;
        setTimeout(triggerFlash, nextFlashDelay);
      }, { once: true });
    }
    setTimeout(triggerFlash, 2000);
  }

  document.addEventListener('DOMContentLoaded', initFilmDefects);
  document.addEventListener('astro:page-load', initFilmDefects);
</script>