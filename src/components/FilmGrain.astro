---
// src/components/FilmGrain.astro
---

<div class="film-container">
    <div class="vignette"></div>
    <div class="gate-stutter top"></div>
    <div class="gate-stutter bottom"></div>
    <div class="line" data-line></div>
    <div class="line" data-line></div>
    <div class="line" data-line></div>
    <div class="dust"></div>
    <div id="frame-flash"></div>
  </div>

  <style>
    .film-container {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 100;
        pointer-events: none;
        overflow: hidden;
        /* Adjusted shiver to be subtler so it doesn't fight with gate stutter */
        animation: film-shiver 0.2s infinite;
    }

    @keyframes film-shiver {
        0% { transform: translateX(0); }
        50% { transform: translateX(0.4px) translateY(0.1px); }
        100% { transform: translateX(0); }
    }

    /* 1. SOFT VIGNETTE */
    /* Uses CSS variables to detect light/dark mode automatically */
    .vignette {
        position: absolute;
        inset: 0;
        z-index: 10;
        background: radial-gradient(circle, transparent 40%, rgba(0, 0, 0, 0.25) 100%); /*Light mode vignette*/
    }

    :global(.dark) .vignette {
        background: radial-gradient(circle, transparent 40%, rgba(215, 215, 215, 0.07) 100%); /*Dark mode vignette*/
    }

    /* DUST & OTHER ELEMENTS */
    .dust {
        position: absolute;
        inset: -50%;
        width: 200%;
        height: 200%;
        opacity: 0.3;
        filter: invert(1);
        background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
        background-size: 50vw 50vw;
        animation: dust-jump 0.6s steps(1) infinite;
    }
 
    @keyframes dust-jump {
        0%   { background-position: 0% 0%; }
        25%  { background-position: 20% 40%; }
        50%  { background-position: 60% 10%; }
        75%  { background-position: 40% 90%; }
    }

    :global(.dark) .dust {
        opacity: 0.2;
    }

    .line {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 0.5px;
        background: rgba(0, 0, 0, 0.4);
        box-shadow: 0 0 1px rgba(0, 0, 0, 0.2);
        display: none;
    }

    :global(.dark) .line {
        background: rgba(215, 215, 215, 0.4); /* Light lines for dark mode */
        box-shadow: 0 0 1px rgba(215, 215, 215, 0.2);
    }

    #frame-flash {
        position: absolute;
        inset: 0;
        background: #000;
        opacity: 0; 
    }

    :global(.dark) #frame-flash {
        background: #d7d7d7;
    }

    .active-flash {
        animation: quick-flash 0.1s steps(1);
    }

    @keyframes quick-flash {
        0% { opacity: 0.15; }
        100% { opacity: 0; }
    }
  </style>

  <script>
    function initFilmDefects() {
      const lines = document.querySelectorAll('[data-line]');

      lines.forEach((lineElement) => {
        const line = lineElement as HTMLElement;
        const randomizeLine = () => {
          line.style.left = `${Math.random() * 100}%`;
          line.style.display = 'block';

          const onScreenDuration = 25 + Math.random() * 175;
         
          setTimeout(() => {
            line.style.display = 'none';
            const waitDuration = 1000 + Math.random() * 9000;
            setTimeout(randomizeLine, waitDuration);
          }, onScreenDuration);
        };
        randomizeLine();
      });

      const flash = document.getElementById('frame-flash');

      function triggerFlash() {
        if (!flash) return;
        flash.classList.add('active-flash');
        flash.addEventListener('animationend', () => {
          flash.classList.remove('active-flash');
          const nextFlashDelay = 5000 + Math.random() * 45000;
          setTimeout(triggerFlash, nextFlashDelay);
        }, { once: true });
      }
      setTimeout(triggerFlash, 2000);
    }

    document.addEventListener('DOMContentLoaded', initFilmDefects);
    document.addEventListener('astro:page-load', initFilmDefects);
  </script>