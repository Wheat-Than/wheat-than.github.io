---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import aboutPhoto from '../assets/EG_Prof_Headshot.jpg';
import velociPhoto from '../assets/EG_VelociCoaster_Photo.jpg';
---

<BaseLayout>
  <div id="main-content" class="film-snap-reveal">
    <section class="side-margins bio-container">
      <div class="bio-text">
        <h1 class="greeting">About Me</h1>
        <p class="intro-paragraph">
          I'm a current Senior at Purdue University graduating in Fall 2026. I'm majoring in Multidisciplinary 
          Engineering, concentrating in Theatre Engineering, with minors in Theatre Design and Production and 
          Design and Innovation. I'm an aspiring engineer, creative, and storyteller, hoping to combine my love 
          of entertainment with the science of engineering to create new story driven experiences.
        </p>

        <div class="resume-link">
          <a href="/Ethan Gray's Resume.pdf" target="_blank" rel="noopener noreferrer" class="view-project">
            Access PDF Resume →
          </a>
        </div>        
      </div>

      <div class="bio-image">
        <Image 
          src={aboutPhoto} 
          alt="Ethan Gray Professional Headshot" 
          class="headshot"
        />
      </div>
    </section>
    <section class="side-margins bio-container reverse-layout">
      <div class="bio-text">
        <h1 class="greeting what-is">What is Theatre Engineering?</h1>
        <p class="intro-paragraph">
          Theatre Engineering is a <strong>unique, ABET accredited</strong> engineering major at Purdue which explores 
          the application of <strong>Mechanical, Civil, and Electrical engineering</strong> principles in entertainment 
          environments. My coursework branches across schools in the College of Engineering and includes 
          courses within the Department of Theatre and Dance's MFA <strong>Technical Direction</strong> program. This allows me to 
          fully explore the applications of my <strong>engineering knowledge in live entertainment settings</strong>, including 
          theme parks, concerts, and theatrical productions.
        </p>
      </div>
      <div class="bio-image">
        <Image 
          src={velociPhoto} 
          alt="Ethan Gray Professional Headshot" 
          class="headshot"
        />
      </div>
    </section>

    <section class="side-margins awards-container">
      <h2 class="section-title">Awards & Recognition</h2>
      <ul class="awards-list">
        <li><strong>Dean's List and Semester Honors</strong> <br/> — Purdue University (2022 - Present)</li>
        <li><strong>Outstanding Senior Academic Achievement</strong> <br/> — Purdue University (2026)</li>
        <li><strong>Commendation for Technical Communication - Attractions Design</strong> <br/> — Toronto 
          Metropolitan Thrill Design Competition, (2025)</li>
        <li><strong>Outstanding Service</strong> <br/> — Purdue University (2025)</li>
        <li><strong>Outstanding Sophomore Academic Achievement</strong> <br/> — Purdue University (2024)</li>
        <li><strong>International Honor Thespian</strong> <br/> — Educational Theater Association (2022)</li>
        <li><strong>California Senior Honor Thespian</strong> <br/> — Educational Theatre Association (2022)</li>
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  /* Identical spacing logic to index.astro */
  p { margin: 0; padding: 0; }
  p + p { margin-top: 1.5rem; }

  .resume-link {
    margin-top: 2rem;
  }

  .awards-container {
    margin-top: 2rem;
  }

  .awards-list {
    list-style: none;
    padding: 0;
  }

  .awards-list li {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    padding-left: 25px;
    position: relative;
  }

  /* Engineering-style bullet points */
  .awards-list li::before {
    content: ">";
    color: #dc5209;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .bio-container {
    display: flex;
    flex-direction: column-reverse; /* Put image on top for mobile */
    gap: 20px;
  }

  /* Desktop layout mirroring index.astro */
  @media screen and (min-width: 800px) {
    .bio-container {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 50px;
    }
    .bio-text { flex: 1; }
    .bio-image { 
      flex: 0 0 300px;
      margin-top: 3rem; 
    }
  }

  .headshot {
    width: 100%;
    height: auto;
    display: block;
  }

  .reverse-layout {
    flex-direction: row-reverse;
  }

  .what-is {
    line-height: 1.1;
    margin-bottom: 1.65rem;
  }
</style>