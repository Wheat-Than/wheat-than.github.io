---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
// Replace this with your actual image path
// import aboutPhoto from '../assets/Ethan_Working.jpg'; 
---

<BaseLayout>
  <div id="main-content" class="film-snap-reveal">
    
    <section class="side-margins">
      <h1 class="greeting">About Me</h1>
    </section>

    <section class="side-margins bio-container">
      <div class="bio-text">
        <p class="intro-paragraph">
          [Insert your main professional bio here. Talk about your passion for 
          technical direction and how your time at Purdue has shaped your 
          engineering approach.]
        </p>
        
        <p>
          [Insert a second paragraph here about your specific interests, 
          like 3D printing workflows or scenic automation.]
        </p>

        <div class="resume-link">
          <a href="/Ethan_Gray_Resume.pdf" class="view-project" target="_blank">
            Access PDF Resume →
          </a>
        </div>
      </div>

      <!-- div class="bio-image">
        <Image 
          src={aboutPhoto} 
          alt="Ethan Gray working on a project" 
          class="headshot"
          width="400" 
          height="400" 
        />
      </div -->
    </section>

    <section class="side-margins awards-container">
      <h2 class="section-title">Awards & Recognition</h2>
      <ul class="awards-list">
        <li><strong>Honors Multidisciplinary Engineering</strong> — Purdue University</li>
        <li><strong>Technical Achievement Award</strong> — [Organization Name] (2025)</li>
        <li><strong>Grant Recipient</strong> — Leonardo da Vinci Animatronic Research</li>
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  /* Identical spacing logic to index.astro */
  p { margin: 0; padding: 0; }
  p + p { margin-top: 1.5rem; }

  .resume-link {
    margin-top: 2rem;
  }

  .awards-container {
    margin-top: 4rem;
    margin-bottom: 6rem;
  }

  .awards-list {
    list-style: none;
    padding: 0;
  }

  .awards-list li {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    padding-left: 25px;
    position: relative;
  }

  /* Engineering-style bullet points */
  .awards-list li::before {
    content: ">";
    color: #dc5209;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  /* Desktop layout mirroring index.astro */
  @media screen and (min-width: 800px) {
    .bio-container {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 50px;
    }
    .bio-text { flex: 1; }
    .bio-image { flex: 0 0 300px; }
  }
</style>