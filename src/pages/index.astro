---
import BaseLayout from '../layouts/BaseLayout.astro';
import Intro from '../components/Intro.astro';
import { Image } from 'astro:assets';
import coverPhoto from '../assets/Diagon_Headshot.jpg';
const pageTitle = null;
---
<BaseLayout pageTitle={pageTitle}>
  <Intro src="/videos/SMPTE Lead In 2.mp4" />

  <div id="main-content" class="film-snap-reveal">
    <section class="side-margins bio-container">
      
      <div class="bio-text">
        <h2 class="greeting">Hi there!</h2>
        
        <p class="intro-paragraph">
          My name is <strong>Ethan Gray</strong>. I'm a senior at Purdue University studying 
          <strong>Multidisciplinary Engineering</strong> with a concentration in <strong>Theatre Engineering</strong>.
        </p>

        <p>
          I'm pursuing a career in design engineering for the entertainment industry. 
          At Purdue, I've developed hands-on skills which I've applied directly to the 
          intersection of technology and the arts. I'm looking to utilize my love for 
          storytelling, collaboration, and creativity to develop new scales of 
          immersive and interactive experiences.
        </p>

        <p>
          <strong>If you're wondering why this website is so odd, me too! It's still under construction. Thank you for your patience.</strong>
        </p>

        <a href="https://ethangrayengineer.wixsite.com/portfolio">Please follow this link to my built site!</a>
      </div>

      <div class="bio-image">
        <Image 
          src={coverPhoto} 
          alt="Ethan Gray Headshot" 
          class="headshot"
          width="400" 
          height="400" 
        />
      </div>

    </section>
    <section class="side-margins project-gallery">
      <h2 class="section-title">Selected Works</h2>
      
      <div class="project-grid">
        <a href="/projects/theatre-automation" class="project-card">
          <div class="card-image-wrapper">
            <Image src={coverPhoto} alt="Project Name" width="400" height="250" />
          </div>
          <div class="card-content">
            <h3>Stage Automation System</h3>
            <p>Mechanical design and PLC integration for high-speed scenic transitions.</p>
            <span class="view-project">View Technical Case Study →</span>
          </div>
        </a>
    
        <a href="/projects/structural-design" class="project-card">
          <div class="card-image-wrapper">
            <div class="placeholder-img"></div> </div>
          <div class="card-content">
            <h3>Structural Rigging Analysis</h3>
            <p>Finite Element Analysis (FEA) for overhead arena rigging points.</p>
            <span class="view-project">View Technical Case Study →</span>
          </div>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  html::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  html {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  
  /* --- 1. THE TEXT RESET --- */
  /* This kills the default browser padding/margins on all text blocks */
  p {
    margin: 0;
    padding: 0;
  }

  /* This adds spacing ONLY between two paragraphs, keeping the 
     top and bottom of the whole block perfectly flush */
  p + p {
    margin-top: 1.5rem;
  }

  .bio-container {
    display: flex;
    flex-direction: column;
    gap: 30px;
    align-items: center;
    margin-top: 0;
  }

  .greeting {
    font-family: 'Courier New', Courier, monospace;
    font-size: 3rem;
    /* Resetting the H2 margin to align perfectly with the top of the image */
    margin: 0 0 1rem 0; 
    color: #dc5209; /* Your burnt orange accent */
  }

  .intro-paragraph {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  .headshot {
    border-radius: 25px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    filter: sepia(0.2) contrast(1.1);
    display: block; /* Removes the tiny gap browsers put under images */
  }

  .project-gallery {
  margin-top: 6rem;
  margin-bottom: 6rem;
}

.section-title {
  font-family: 'Courier New', Courier, monospace;
  color: #dc5209;
  font-size: 2rem;
  margin-bottom: 2rem;
}

.project-grid {
  display: grid;
  grid-template-columns: 1fr; /* Stacked on mobile */
  gap: 30px;
}

.project-card {
  text-decoration: none;
  color: inherit;
  background: rgba(215, 215, 215, 0.3); /* Subtle glass base */
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border 0.3s ease;
}

/* DARK MODE ADJUSTMENT */
:global(.dark) .project-card {
  background: rgba(20, 20, 20, 0.5);
  border: 1px solid rgba(215, 215, 215, 0.1);
}

.project-card:hover {
  transform: translateY(-5px);
  border: 1px solid rgba(220, 82, 9, 0.6);
  box-shadow: 0 10px 30px rgba(220, 82, 9, 0.2);
}

.card-image-wrapper {
  width: 100%;
  height: 200px;
  overflow: hidden;
  background: #161616;
}

.card-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.project-card:hover img {
  transform: scale(1.05);
}

.card-content {
  padding: 20px;
}

.card-content h3 {
  margin: 0 0 10px 0;
  font-size: 1.4rem;
}

.card-content p {
  font-size: 0.95rem;
  opacity: 0.8;
  margin-bottom: 15px;
}

.view-project {
  font-size: 0.85rem;
  font-weight: bold;
  color: #dc5209;
  text-transform: uppercase;
  letter-spacing: 1px;
}


  /* --- 2. DESKTOP ALIGNMENT --- */
  @media screen and (min-width: 800px) {
    .bio-container {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .bio-text {
      flex: 1;
    }

    .bio-image {
      flex: 0 0 300px;
    }

    .project-grid {
      grid-template-columns: repeat(2, 1fr); /* Side-by-side on desktop */
    } 
  }
</style>