---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import cupcake from '../../assets/Mr_Cupcake_Resin_Print.jpg';
import coasterTrain from '../../assets/Coaster_Train_1.png';
import equalizer from '../../assets/Audio_Equalizer.png';
import eddy from '../../assets/Mech_Design_1.png'
import ATD from '../../assets/Gloria_ATD_1.png';
import website from '../../assets/website_1.png'
---
<BaseLayout>
  <div id="main-content" class="film-snap-reveal">
    <h1>Projects</h1>
    <section class="side-margins project-gallery">
      <div class="project-grid">

          <!-- Mr Cupcake -->    
          <a href="/portfolio/MrCupcake" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={cupcake} alt="Mr. Cupcake, printed in resin on Formlabs Form 4L." width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>Mr. Cupcake Mechatronic Toy</h3>
              <p>Designing and building a prototype RC toy inspired by Five Nights at Freddy's.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>

          <!-- This Website -->    
          <a href="/portfolio/meta" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={website} alt="HTML Code" width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>This Website!</h3>
              <p>Design, programming, and implementation of a personal portfolio using the Astro framework.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>

          <!-- ATD on Gloria -->
          <a href="/portfolio/ATD_Gloria" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={ATD} alt="Scenery for a production of Gloria." width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>Assistant Technical Direction Project</h3>
              <p>Drafting custom stage scenery and performing cost and time estimates.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>

          <!-- 3D Printed Coaster Project -->
          <a href="/portfolio/3D_Coaster" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={coasterTrain} alt="CAD file of scale model roller coaster train." width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>3D Printed Roller Coaster</h3>
              <p>Utilizing advanced CAD techniques to design a functioning scale model.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>

          <!-- Mechanical Design for the Stage -->
          <a href="/portfolio/Mech_Design" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={eddy} alt="CAD file showcasing an eddy current braking system for stage scenery." width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>Mechanical Design for the Stage</h3>
              <p>Concept and detailed design for stage machines in complex show environments.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>

          <!-- ECE 2k1 Audio Equalizer -->
          <a href="/portfolio/Audio_Equalizer/" class="project-card">
            <div class="card-image-wrapper">
              <div class="placeholder-img"></div> 
                <Image src={equalizer} alt="Audio Equalizer" width="400" height="250"/>
              </div>
            <div class="card-content">
              <h3>Analog Audio Equalizer</h3>
              <p>RC and RCL filters implemented in a 3-channel, basic audio equalizer.</p>
              <span class="view-project">View Project →</span>
            </div>
          </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
    /* Hide scrollbar for Chrome, Safari and Opera */
    html::-webkit-scrollbar {
      display: none;
    }
  
    /* Hide scrollbar for IE, Edge and Firefox */
    html {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }
    
    /* --- 1. THE TEXT RESET --- */
    /* This kills the default browser padding/margins on all text blocks */
    p {
      margin: 0;
      padding: 0;
    }
  
    /* This adds spacing ONLY between two paragraphs, keeping the 
       top and bottom of the whole block perfectly flush */
    p + p {
      margin-top: 1.5rem;
    }
  
    .bio-container {
      display: flex;
      flex-direction: column;
      gap: 30px;
      align-items: center;
      margin-top: 0;
    }
  
    .greeting {
      font-family: 'Courier New', Courier, monospace;
      font-size: 3rem;
      /* Resetting the H1 margin to align perfectly with the top of the image */
      margin: 0 0 1rem 0;
      margin-top: 2.5rem;
      color: #dc5209; /* Your burnt orange accent */
    }
  
    .intro-paragraph {
      font-size: 1.2rem;
      line-height: 1.6;
    }
  
  .project-gallery {
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
  
  .section-title {
    font-family: 'Courier New', Courier, monospace;
    color: #dc5209;
    font-size: 2rem;
    margin-bottom: 2rem;
  }
  
  .project-grid {
    display: grid;
    grid-template-columns: 1fr; /* Stacked on mobile */
    gap: 30px;
  }
  
  .headshot {
      margin-top: 3rem;
      width = 100%;
      height = auto;
  }
  
  .project-card {
    text-decoration: none;
    color: inherit;
    background: rgba(215, 215, 215, 0.3); /* Subtle glass base */
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border 0.3s ease;
  }
  
  /* DARK MODE ADJUSTMENT */
  :global(.dark) .project-card {
    background: rgba(20, 20, 20, 0.5);
    border: 1px solid rgba(215, 215, 215, 0.1);
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    border: 1px solid rgba(220, 82, 9, 0.6);
    box-shadow: 0 10px 30px rgba(220, 82, 9, 0.2);
  }
  
  .card-image-wrapper {
    width: 100%;
    height: 300px;
    overflow: hidden;
    background: #161616;
  }
  
  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .project-card:hover img {
    transform: scale(1.05);
  }
  
  .card-content {
    padding: 20px;
  }
  
  .card-content h3 {
    margin: 0 0 10px 0;
    font-size: 1.4rem;
  }
  
  .card-content p {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 15px;
  }
  
  .view-project {
    font-size: 0.85rem;
    font-weight: bold;
    color: #dc5209;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  
    /* --- 2. DESKTOP ALIGNMENT --- */
    @media screen and (min-width: 800px) {
      .bio-container {
        flex-direction: row;
        align-items: flex-start;
        justify-content: space-between;
      }
  
      .bio-text {
        flex: 1;
      }
  
      .bio-image {
        flex: 0 0 300px;
      }
  
      .project-grid {
        grid-template-columns: repeat(2, 1fr); /* Side-by-side on desktop */
      } 
    }
  </style>